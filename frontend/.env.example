# Frontend environment variables
# Copy this file to .env and fill in your values

VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Optional: Set API URL for production or non-proxy setups
# In development, the Vite proxy forwards /api to localhost:8000 automatically
# In production (when served from backend), leave this unset
# VITE_API_URL=http://localhost:8000
