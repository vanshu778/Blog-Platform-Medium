# Frontend environment variables
# Copy this file to .env and fill in your values

VITE_GOOGLE_CLIENT_ID=your_google_client_id

# API URL — set this to your Render backend URL for production
# In development, the Vite proxy forwards /api to localhost:8000 automatically
# In production on Vercel, set this to your Render backend URL (no trailing slash)
# Example: https://your-backend.onrender.com
# VITE_API_URL=https://your-backend.onrender.com
